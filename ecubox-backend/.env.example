# ECUBOX backend environment example
# Copy this file to `.env` inside `ecubox-backend/` and fill real values.
# Never commit `.env`.
#
# Docs: docs/despliegue/VARIABLES_ENTORNO.md

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
PORT=8080

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/ecubox_v1
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# Required. Use at least 32 characters.
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRATION=86400000
JWT_ISSUER=ecubox-backend

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API.
# Local dev:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
# Production example:
# CORS_ALLOWED_ORIGINS=https://ecubox.com,https://www.ecubox.com

# -----------------------------------------------------------------------------
# Initial admin bootstrap
# -----------------------------------------------------------------------------
# Use only for first setup. In production, set ADMIN_BOOTSTRAP_ENABLED=false
# after the first admin user has been created.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.invalid
ADMIN_INITIAL_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Tracking / outbox
# -----------------------------------------------------------------------------
# Optional. Defaults are already defined in application.properties.
TRACKING_TIMELINE_USE_EVENTS=true
TRACKING_OUTBOX_RELAY_DELAY_MS=5000
TRACKING_OUTBOX_MAX_ATTEMPTS=6

# Public endpoint rate limits
AUTH_RATELIMIT_ENABLED=true
AUTH_RATELIMIT_CAPACITY=10
AUTH_RATELIMIT_REFILL_TOKENS=10
AUTH_RATELIMIT_REFILL_PERIOD_SECONDS=60

# Enable only when a trusted reverse proxy overwrites forwarding headers.
TRUST_FORWARDED_HEADERS=false

# Hibernate tuning
HIBERNATE_JDBC_BATCH_SIZE=50
HIBERNATE_BATCH_FETCH_SIZE=32

# -----------------------------------------------------------------------------
# Web Push / PWA notifications
# -----------------------------------------------------------------------------
# Enables real push notifications when the PWA is closed.
#
# Generate VAPID keys once:
#   npx web-push generate-vapid-keys
#
# WEB_PUSH_SUBJECT must identify your server/contact. Prefer a real business
# email in production, for example: mailto:soporte@ecubox.com
#
# Keep WEB_PUSH_PRIVATE_KEY secret. Never put it in frontend .env files.
WEB_PUSH_ENABLED=false
WEB_PUSH_SUBJECT=mailto:dev@example.invalid
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Production checklist
# -----------------------------------------------------------------------------
# - SPRING_PROFILES_ACTIVE=prod
# - DB_URL points to production PostgreSQL, usually with sslmode=require.
# - JWT_SECRET is unique, random, and not reused from development.
# - CORS_ALLOWED_ORIGINS contains only production frontend origins.
# - ADMIN_BOOTSTRAP_ENABLED=false after first setup.
# - WEB_PUSH_ENABLED=true only after VAPID keys are configured.
