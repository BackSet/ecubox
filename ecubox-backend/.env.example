# Copiar a .env y rellenar valores. No commitear .env.
# Backend ECUBOX - variables de entorno
#
# El backend carga este archivo (.env) automáticamente desde el directorio de trabajo
# al arrancar. Para que se cree el usuario admin en el primer arranque, definir
# ADMIN_BOOTSTRAP_ENABLED=true y ADMIN_INITIAL_PASSWORD (y opcionalmente ADMIN_USERNAME).
#
# Los comentarios con "# ...=" son solo formato tentativo (datos ficticios, no reales).
# Documentación: docs/despliegue/VARIABLES_ENTORNO.md

SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/ecubox_v1
DB_USERNAME=postgres
DB_PASSWORD=

JWT_SECRET=
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Opcionales tracking (valores por defecto en application.properties si se omiten)
# TRACKING_TIMELINE_USE_EVENTS=true
# TRACKING_OUTBOX_RELAY_DELAY_MS=5000
# TRACKING_OUTBOX_MAX_ATTEMPTS=6

# Producción: definir variables reales en tu entorno (no uses literales de ejemplo).
# JWT_SECRET: mínimo 32 caracteres para HS256.

# Bootstrap primer usuario ADMIN (solo primer arranque; revisar política en prod)
# ADMIN_EMAIL obligatorio si ADMIN_BOOTSTRAP_ENABLED=true.
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=ejemplo-admin@dominio-ficticio.invalid
ADMIN_INITIAL_PASSWORD=
