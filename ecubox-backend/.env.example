# Copiar a .env y rellenar valores. No commitear .env.
# Backend ECUBOX - variables de entorno
#
# El backend carga este archivo (.env) automáticamente desde el directorio de trabajo
# al arrancar. Para que se cree el usuario admin en el primer arranque, definir
# ADMIN_BOOTSTRAP_ENABLED=true y ADMIN_INITIAL_PASSWORD (y opcionalmente ADMIN_USERNAME).

SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/ecubox_v1
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Producción: usar SPRING_PROFILES_ACTIVE=prod y definir todas las variables sin valores por defecto.
# JWT_SECRET debe tener al menos 32 caracteres (256 bits) para HS256.

# Bootstrap primer usuario ADMIN (solo primer arranque; no usar en prod sin control)
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=
