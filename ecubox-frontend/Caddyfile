:80

encode zstd gzip
root * /srv/dist

# Recursos con hash de contenido en /assets/*: cache larga e inmutable. El hash
# del nombre cambia en cada build, asi que nunca sirve contenido obsoleto.
@immutable {
	path /assets/*
}
header @immutable Cache-Control "public, max-age=31536000, immutable"

# Artefactos sin hash que deben revalidarse en cada deploy. Si se cachean de
# forma agresiva, el service worker o el index quedan desincronizados de los
# chunks nuevos y la PWA falla al cargar modulos dinamicos.
@no_cache {
	path /sw.js /sw.js.map /registerSW.js /workbox-*.js /manifest.webmanifest /index.html / /icons/*
}
header @no_cache Cache-Control "no-cache"

header {
	X-Content-Type-Options nosniff
	X-Frame-Options DENY
	Referrer-Policy strict-origin-when-cross-origin
}

# Recursos con hash: si el archivo no existe (chunk de un build anterior tras
# un deploy), responder 404 limpio. NUNCA caer al fallback SPA, que serviria
# index.html con Content-Type text/html y rompe el import dinamico con el error
# "MIME type ('text/html') is not a valid JavaScript MIME type".
handle /assets/* {
	file_server
}

# Resto de rutas: fallback SPA al index.html para el enrutado del cliente.
handle {
	try_files {path} /index.html
	file_server
}
