# Copiar a .env y ajustar. No commitear .env ni .env.local.
# Frontend ECUBOX - variables de entorno (se embeben en el build; no poner secretos)
#
# Valores mostrados son tentativos. Sustituye por la URL real de tu API.
# Documentación: docs/despliegue/VARIABLES_ENTORNO.md

# Desarrollo local (npm run dev), backend en la misma máquina (origen solo o con /api):
# VITE_API_URL=http://localhost:8080
# VITE_API_URL=http://localhost:8080/api

# Placeholder genérico — reemplaza por la URL pública de tu API (añade `/api` al final si tu backend lo usa):
VITE_API_URL=https://api-ejemplo-reemplazar.invalid

# URL pública del frontend (sin barra final): canonical, Open Graph, JSON-LD y sitemap en build.
# Producción: https://ecubox.org
# VITE_PUBLIC_SITE_URL=https://ecubox.org
