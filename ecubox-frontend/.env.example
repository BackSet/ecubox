# ECUBOX frontend environment example
# Copy this file to `.env` inside `ecubox-frontend/`.
#
# Vite embeds VITE_* variables into the browser bundle.
# Do not put secrets here.
#
# Docs: docs/despliegue/VARIABLES_ENTORNO.md

# -----------------------------------------------------------------------------
# API URL
# -----------------------------------------------------------------------------
# Local development:
VITE_API_URL=http://localhost:8080

# If you prefer to include /api explicitly, this also works:
# VITE_API_URL=http://localhost:8080/api

# Docker Compose from the browser usually still points to localhost:
# VITE_API_URL=http://localhost:8080

# Production examples:
# VITE_API_URL=https://api.ecubox.com
# VITE_API_URL=https://api.ecubox.com/api

# -----------------------------------------------------------------------------
# Public site URL
# -----------------------------------------------------------------------------
# Used for canonical metadata, Open Graph, JSON-LD, and sitemap build output.
# No trailing slash.
# VITE_PUBLIC_SITE_URL=https://ecubox.com

# -----------------------------------------------------------------------------
# Web Push / PWA
# -----------------------------------------------------------------------------
# No frontend env variable is needed for Web Push.
# The app reads the public VAPID key from:
#   GET /api/push/public-key
#
# Never put WEB_PUSH_PRIVATE_KEY here. It belongs only in backend env vars.
