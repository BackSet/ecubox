# Copiar a .env y ajustar. No commitear .env ni .env.local.
# Frontend ECUBOX - variables de entorno (se embeben en el build; no poner secretos)

VITE_API_URL=https://<tu-backend>.up.railway.app/api

# Producción: URL absoluta del backend con prefijo /api, ej. https://api.ecubox.com/api
# En producción la API debe servirse por HTTPS.
# En Railway recomendado: VITE_API_URL=https://<tu-backend>.up.railway.app/api
